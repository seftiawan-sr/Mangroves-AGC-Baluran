#Basic statistical analysis
import pandas as pd
import numpy as np

df = pd.read_csv('Baluran_data_revision2.csv')
print(df.head())

# THIS IS NORMALITY DATA TEST CELL

import pandas as pd
import numpy as np
from scipy.stats import shapiro, normaltest
import matplotlib.pyplot as plt
import seaborn as sns

results = []

for col in df.columns:
    data = df[col].dropna()  # remove NaNs

    # Check if data has variation
    if data.nunique() <= 1:
        results.append({
            'Dataset': col,
            'Shapiro_p': None,
            'Shapiro_Normal': "Constant Data",
            'Dagostino_p': None,
            'Dagostino_Normal': "Constant Data"
        })
        continue

    # Shapiro-Wilk test
    stat_shapiro, p_shapiro = shapiro(data)

    # D’Agostino-Pearson test
    stat_dagostino, p_dagostino = normaltest(data)

    results.append({
        'Dataset': col,
        'Shapiro_p': p_shapiro,
        'Shapiro_Normal': p_shapiro > 0.05,
        'Dagostino_p': p_dagostino,
        'Dagostino_Normal': p_dagostino > 0.05
    })

# Convert results to DataFrame
results_df = pd.DataFrame(results)

print(results_df)

# Save results to Excel
results_df.to_excel("AGC_normality_test_results_revision2.xlsx", index=False)

