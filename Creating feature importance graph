#FEATURE IMPORTANCE OF THREE VARIABLES
#RVI, TSAVI, HA
 
import matplotlib.pyplot as plt
import pandas as pd
import numpy as np
import joblib
import os

# Load dataset
df = pd.read_csv('Baluran_data_revision2.csv')
X = df[['TSAVI_rev2','RVI_rev2','HA']]
y = df['AGC']

# Train-test split
from sklearn.model_selection import train_test_split
X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.3, random_state=42
)

# Train Random Forest (RF)
from sklearn.ensemble import RandomForestRegressor
rf_model = RandomForestRegressor(n_estimators=1000, random_state=42)
rf_model.fit(X_train, y_train)

# Feature importances
importances = rf_model.feature_importances_ * 100  # convert to percentage
feature_names = ['TSAVI', 'RVI','Tree Height']  # renamed for clarity

# Sort features by importance
indices = np.argsort(importances)[::-1]
sorted_importances = importances[indices]
sorted_features = [feature_names[i] for i in indices]

# Display feature importances
feature_df = pd.DataFrame({
    'Feature': sorted_features,
    'Importance (%)': sorted_importances
})
print(feature_df)

# Plot
plt.figure(figsize=(8,6))
bars = plt.bar(sorted_features, sorted_importances, color="#1f77b4", edgecolor='black')

plt.xticks(fontsize=13)
plt.yticks(fontsize=13)

# Axis labels
plt.xlabel("Predictor Variables", fontsize=14)
plt.ylabel("Relative Importance (%)", fontsize=14)

plt.grid(axis='y', linestyle='--', alpha=0.5)

# Annotate percentage values on top of bars
for bar in bars:
    height = bar.get_height()
    plt.text(bar.get_x() + bar.get_width()/2.0, height + 0.25, f"{height:.0f}%",
             ha='center', va='bottom', fontsize=12)

# Save figure
os.makedirs("model_scatter_plots", exist_ok=True)
plt.tight_layout()
plt.savefig("model_scatter_plots/RF_feature_importance_percentage.png", dpi=600, bbox_inches='tight')

plt.show()
